// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-q": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-n": "workspace::NewTerminal",
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-k": "terminal_panel::ToggleFocus",
      "ctrl-j": "terminal_panel::ToggleFocus",
      "ctrl-q": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-w": "workspace::CloseActiveDock",
      "ctrl-h": "project_panel::ToggleFocus",
      "ctrl-l": "project_panel::ToggleFocus",
      "ctrl-q": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-j": "terminal_panel::ToggleFocus",
      "ctrl-h": "pane::RevealInProjectPanel" ,
      "ctrl-s": "workspace::Save",
      "ctrl-z": "editor::Undo",
      "ctrl-f": "buffer_search::DeployReplace",
      "ctrl-a": "editor::SelectAll",
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
      "ctrl-F": "project_search::ToggleFocus"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "enter": "vim::InsertEmptyLineBelow",
      "L": "vim::EndOfLineDownward",
      "H": "vim::StartOfLineDownward",
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "g c": "editor::FormatSelections"
    }
  }
]
