// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    }
  },
  "disable_ai": true,
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 17,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Dark",
    "dark": "VSCode Dark Polished"
  },
  "ui_font_family": "BlexMono Nerd Font Mono",
  "buffer_font_family": "BlexMono Nerd Font Mono",
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "always"
  },
  "format_on_save": "off",
  "title_bar": {
    "show_branch_icon": true, // Show/hide branch icon beside branch switcher
    "show_branch_name": true, // Show/hide branch name
    "show_project_items": true, // Show/hide project host and name
    "show_onboarding_banner": true, // Show/hide onboarding banners
    "show_user_picture": true, // Show/hide user avatar
    "show_sign_in": true, // Show/hide sign-in button
    "show_menus": true // Show/hide menus
  },
  "terminal": {
    "working_directory": "current_project_directory"
  }
}
